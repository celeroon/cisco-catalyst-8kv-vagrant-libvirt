#!/usr/bin/expect

# Script timeout and target connection details
set timeout 300
set host "127.0.0.1"
set port "52099"
set prompt "(>|#)\\s*$"

# Log file for capturing the session output
log_file -noappend ./cisco-cat8kv-console.explog

# Start a Telnet session to the target device
spawn telnet $host $port

# Disable setup command facility
send "\r"
expect "initial configuration dialog"
send "no\r"
expect "Enter enable secret"
send "SuperSecretPass123$\r"
expect "Confirm enable secret"
send "SuperSecretPass123$\r"
expect "Enter your selection"
send "0\r"
expect "Press RETURN to get started"
send "\r"
#expect "OK to enter CLI now"
#send "\r"

# Enter privileged exec mode
expect -re $prompt
send "enable\r"
expect -re $prompt

# Enter global configuration mode
send "configure terminal\r"
expect -re $prompt

# Activate advantage license
send "license boot level network-premier addon dna-premier\r"
expect -re $prompt

# Exit global configuration mode and save configuration
send "end\r"
expect -re $prompt
send "write memory\r"
expect -re $prompt

# Reboot
send "reload\r"
expect "Proceed with reload"
send "\r"

# Enter CLI 
expect "Press RETURN to get started"
send "\r"

# Enter privileged exec mode
expect -re $prompt
send "enable\r"
expect -re $prompt

# Enter global configuration mode
send "configure terminal\r"
expect -re $prompt

# Create a user account with maximum privileges
send "username vagrant privilege 15 secret vagrant\r"

# Enable AAA features and configure default authentication and authorization methods
expect -re $prompt {
    send "aaa new-model\r"
    send "aaa authentication login default local\r"
    send "aaa authorization exec default local\r"
}

# Disable DNS lookups to avoid delays caused by mistyped commands
send "no ip domain lookup\r"
expect -re $prompt

# Enable shell processing for advanced CLI processing
send "shell processing full\r"

# Configure the primary console line
expect -re $prompt {
    send "line console 0\r"
    send "privilege level 15\r"
    send "exec-timeout 0 0\r"
    send "logging synchronous\r"
    send "exit\r"
}

# Configure the virtual terminal (VTY) lines for SSH access
expect -re $prompt {
    send "line vty 0 4\r"
    send "no exec-banner\r"
    send "exec-timeout 0 0\r"
    send "logging synchronous\r"
    send "transport input ssh\r"
    send "exit\r"
}

# Set up the management interface with a VRF and dynamic IP assignment
expect -re $prompt {
    send "vrf definition Mgmt-intf\r"
    send "address-family ipv4\r"
    send "exit-address-family\r"
    send "exit\r"
    send "interface GigabitEthernet1\r"
    send "shutdown\r"
    send "vrf forwarding Mgmt-intf\r"
    send "ip address dhcp\r"
    send "no cdp enable\r"
    send "no shutdown\r"
    send "exit\r"
}


# Configure SSH with necessary parameters
expect -re $prompt {
    send "ip domain name example.com\r"
    send "ip ssh version 2\r"
    send "ip ssh source-interface GigabitEthernet1\r"
    send "ip ssh rsa keypair-name VAGRANT\r"
    send "crypto key generate rsa usage-keys label VAGRANT modulus 2048\r"
    send "ip scp server enable\r"
    send "ip ssh pubkey-chain\r"
    send "username vagrant\r"
    send "key-hash ssh-rsa DD3BB82E850406E9ABFFA80AC0046ED6\r"
    send "exit\r"
}

# Create an EEM applet to regenerate RSA keys automatically after a device restart
expect -re $prompt {
    send "event manager session cli username vagrant\r"
    send "event manager applet EEM_SSH_Keygen authorization bypass\r"
    send "event syslog pattern SYS-5-RESTART\r"
    send "action 0.0 set status none\r"
    send "action 1.0 cli command enable\r"
    send "action 2.0 cli command \"show ip ssh | include \^SSH\"\r"
    send "action 2.1 regexp \"\(\[ED]\[\^ \]\+)\" \\\$_cli_result result status\r"
    send "action 2.2 syslog priority informational msg \"SSH is currently \\\$status\"\r"
    send "action 3.0 if \\\$status eq Disabled\r"
    send "action 3.1 cli command \"configure terminal\"\r"
    send "action 3.2 cli command \"crypto key generate rsa usage-keys label VAGRANT modulus 2048\"\r"
    send "action 3.3 cli command \"end\"\r"
    send "action 3.4 cli command \"copy run start\"\r"
    send "action 3.5 syslog priority informational msg \"SSH keys generated by EEM\"\r"
    send "action 4.0 end\r"
    send "end\r"
}

# Enable netconf
expect -re $prompt {
    send "conf t\r"
    send "netconf-yang\r"
    send "end\r"
}

# Save the running configuration to the startup configuration
send "copy running-config startup-config\r"
expect "Destination filename"
send "\r"
expect -re $prompt

# Pause briefly to ensure the save process completes
sleep 5
