# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Use Vagrant's default insecure key for SSH
  config.ssh.insert_key = false
  # Set boot timeout to 3 minutes
  config.vm.boot_timeout = 180
  # Disable default shared folder between host and guest
  config.vm.synced_folder ".", "/vagrant", disabled: true
  # Prevent Vagrant from modifying fstab inside the guest VM
  config.vm.allow_fstab_modification = false
  # Prevent Vagrant from modifying the hosts file inside the guest VM
  config.vm.allow_hosts_modification = false
  # Explicitly set the guest OS type to FreeBSD to avoid autodetection issues
  config.vm.guest = :freebsd

  # Configure the Libvirt provider settings
  config.vm.provider :libvirt do |libvirt|
    # Allocate 2 CPU cores to the VM
    libvirt.cpus = 2
    # Assign 4GB of RAM to the VM
    libvirt.memory = 4096 
    # Enable ACPI support (helps with power management and shutdown handling)
    libvirt.features = ['acpi']
    # Set disk caching mode to 'none' for better consistency in virtualization environments
    libvirt.disk_driver :cache => 'none'
    # Use the VirtIO bus for disk operations to optimize performance
    libvirt.disk_bus = "virtio"
    # Use the VirtIO model for network interfaces to improve network performance
    libvirt.nic_model_type = "virtio"
    # Disable graphical output
    libvirt.graphics_type = "none"
    # Set video type to 'cirrus' for compatibility
    libvirt.video_type = "cirrus"
  end
end
